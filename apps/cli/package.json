{
  "name": "@freed/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "freed": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin.ts",
    "start": "node dist/bin.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@freed/models": "workspace:*",
